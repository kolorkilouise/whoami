{
  // CSpell
  "cSpell.language": "en, pt-BR",
  "cSpell.words": [
    "ctype",
    "esnext",
    "Etec",
    "FIDC",
    "github",
    "Gres",
    "Horusec",
    "Karmada",
    "LARC",
    "LGPD",
    "linenumber",
    "Linkedin",
    "peaceiris",
    "Softfocus",
    "Stackgres",
    "tailwindcss",
    "Vinicius"
  ],

  // Tailwind CSS
  "files.associations": {
    "*.css": "tailwindcss"
  },

  // Angular
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.lineNumbers": "on",
    "editor.minimap.enabled": false,
    "editor.occurrencesHighlight": "off",
    "editor.suggest.insertMode": "replace",
    "editor.wordWrap": "on"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.lineNumbers": "on",
    "editor.minimap.enabled": false,
    "editor.occurrencesHighlight": "off",
    "editor.wordWrap": "on"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "angular.enable-strict-mode-prompt": false,
  "bookmarks.navigateThroughAllFiles": true,
  "bookmarks.wrapNavigation": true,
  "breadcrumbs.enabled": true,
  "breadcrumbs.showFiles": true,
  "debug.console.fontSize": 13,
  "debug.internalConsoleOptions": "openOnSessionStart",
  "debug.openDebug": "openOnDebugBreak",
  "deno.enablePaths": ["supabase/functions"],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.fontFamily": "'FiraCode Nerd Font', 'Cascadia Code'",
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.minimap.enabled": false,
  "editor.quickSuggestions": {
    "comments": false,
    "other": true,
    "strings": true
  },
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.tabCompletion": "on",
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 80,
  "emmet.includeLanguages": {
    "javascript": "html",
    "typescript": "html"
  },
  "emmet.triggerExpansionOnTab": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.fontFamily": "FiraCode Nerd Font, Cascadia Code",
  "errorLens.fontSize": "12",
  "errorLens.removeLinebreaks": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.routes.ts": "${capture}.module.ts, ${capture}.module.spec.ts",
    "*.service.ts": "${capture}.service.spec.ts",
    "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.js.map, ${capture}.spec.ts, ${capture}.stories.ts, ${capture}.html, ${capture}.css, ${capture}.spec.ts",
    ".gitignore": ".gitattributes, .gitmodules, .gitmessage, .mailmap, .git-blame*",
    "README.md": "AUTHORS, BACKERS.md, CHANGELOG*, CONTRIBUTING.md, CONTRIBUTORS, COPYING*, COPYRIGHT, LICENSE*, MAINTAINERS, README*",
    "angular.json": "*.config.js, *.config.ts, *.config.mjs, *.config.cjs, browserslist, karma.conf.js, tsconfig*.json, tslint.json, .eslintrc*, .prettierrc*, nx.json, project.json",
    "firebase.json": "firebase*.json, .firebaserc, firestore.rules, firestore.indexes.json, storage.rules, database.rules.json, remoteconfig.template.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, npm-shrinkwrap.json, .nvmrc, .node-version"
  },
  "explorer.sortOrder": "filesFirst",
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/*-debug.log": true,
    "**/*.js.map": true,
    "**/.DS_Store": true,
    "**/.angular": true,
    "**/.nx": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/CVS": true,
    "**/Thumbs.db": true,
    "**/dist": true,
    "**/firebase-debug.log": true,
    "**/node_modules": true
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "gitlens.blame.compact": true,
  "gitlens.codeLens.enabled": true,
  "html.format.wrapLineLength": 120,
  "html.suggest.html5": true,
  "indentRainbow.colorOnWhiteSpaceOnly": true,
  "indentRainbow.colors": [
    "rgba(255,255,64,0.3)",
    "rgba(127,255,127,0.3)",
    "rgba(255,127,255,0.3)",
    "rgba(79,236,236,0.3)"
  ],
  "indentRainbow.excludedLanguages": ["plaintext", "markdown"],
  "indentRainbow.indicatorStyle": "light",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "markdown.extension.preview.autoShowPreviewToSide": false,
  "markdown.extension.toc.levels": "2..6",
  "markdown.preview.fontFamily": "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
  "markdown.preview.fontSize": 14,
  "markdown.preview.lineHeight": 1.6,
  "markdown.preview.markEditorSelection": true,
  "markdown.preview.openMarkdownLinks": "inPreview",
  "markdown.preview.scrollEditorWithPreview": true,
  "markdown.preview.scrollPreviewWithEditor": true,
  "material-icon-theme.files.customClones": [
    {
      "base": "angular",
      "color": "purple-400",
      "fileExtensions": ["repository.ts"],
      "fileNames": [],
      "lightColor": "purple-600",
      "name": "angular-repository",
      "activeForPacks": ["angular"]
    },
    {
      "base": "angular",
      "color": "orange-400",
      "fileExtensions": ["page.ts"],
      "fileNames": [],
      "lightColor": "orange-600",
      "name": "angular-page",
      "activeForPacks": ["angular"]
    },
    {
      "name": "gemini-main-prompt-md",
      "base": "prompt",
      "color": "yellow-600",
      "lightColor": "yellow-800",
      "fileExtensions": [],
      "fileNames": ["GEMINI.md"]
    },
    {
      "name": "gemini-aux-prompt-md",
      "base": "prompt",
      "color": "green-600",
      "lightColor": "green-800",
      "fileExtensions": [],
      "fileNames": ["*.md"],
      "rootFolderNames": [".gemini"]
    }
  ],
  "material-icon-theme.folders.customClones": [
    {
      "name": "feature",
      "base": "middleware",
      "color": "yellow-600",
      "lightColor": "yellow-600",
      "folderNames": ["feature", "features"]
    },
    {
      "name": "initializer",
      "base": "settings",
      "color": "green-500",
      "lightColor": "green-700",
      "folderNames": ["initializer"]
    },
    {
      "name": "gemini-prompts",
      "base": "prompt",
      "color": "red-400",
      "lightColor": "red-600",
      "folderNames": [".gemini"]
    }
  ],
  "outline.showClasses": true,
  "outline.showFunctions": true,
  "outline.showVariables": false,
  "problems.decorations.enabled": true,
  "search.exclude": {
    "**/*-debug.log": true,
    "**/.nx": true,
    "**/dist": true,
    "**/firebase-debug.log": true,
    "**/node_modules": true
  },
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font', 'Cascadia Code', Consolas, monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.scrollback": 10000,
  "todo-tree.general.tags": ["BUG", "HACK", "FIXME", "TODO", "XXX", "NOTE", "REVIEW", "OPTIMIZE"],
  "todo-tree.highlights.customHighlight": {
    "FIXME": {
      "background": "#FF6B6B20",
      "foreground": "#FF6B6B",
      "icon": "bug",
      "type": "tag"
    },
    "NOTE": {
      "background": "#4ECDC420",
      "foreground": "#4ECDC4",
      "icon": "note",
      "type": "tag"
    },
    "REVIEW": {
      "background": "#95E1D320",
      "foreground": "#95E1D3",
      "icon": "eye",
      "type": "tag"
    },
    "TODO": {
      "background": "#FFD70020",
      "foreground": "#FFD700",
      "icon": "check",
      "type": "tag"
    }
  },
  "typescript.disableAutomaticTypeAcquisition": false,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "readme",
  "workbench.tree.indent": 20,
  "coverage-gutters.coverageBaseDir": "coverage/maker-story",
  "coverage-gutters.showGutterCoverage": true,
  "coverage-gutters.showLineCoverage": false
}
